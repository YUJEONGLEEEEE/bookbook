//  Secret.swift.example
//
//  이 파일을 같은 폴더(bookbook/)에 복사한 뒤 파일명을 `Secret.swift` 로 바꾸고,
//  아래 placeholder 값을 실제 API 키로 채워 넣으세요.
//
//  - 실제 `Secret.swift` 는 .gitignore 로 제외되어 git/GitHub 에 올라가지 않습니다.
//  - 실제 키 값은 프로젝트 관리자에게 직접(카톡/메일 등) 요청하세요.
//  - 키 값을 그대로 문자열로 넣어도 동작합니다. (원한다면 SecretObfuscator.decode 로 난독화 가능)
//  - 빌드만 확인할 목적이면 placeholder 그대로 둬도 컴파일됩니다(네트워크 호출만 실패).

import Foundation

enum APIKey {
    // 공개 엔드포인트(비밀 아님) — 그대로 사용
    static let aladinSearchURL = "https://www.aladin.co.kr/ttb/api/ItemSearch.aspx"
    static let aladinListURL = "https://www.aladin.co.kr/ttb/api/ItemList.aspx"
    static let naverDetailURL = "https://openapi.naver.com/v1/search/book_adv.json"

    // 비밀 키 — 실제 값으로 교체하세요
    static let ttbKey = "YOUR_ALADIN_TTB_KEY"
    static let naverCliendId = "YOUR_NAVER_CLIENT_ID"
    static let naverClientSecret = "YOUR_NAVER_CLIENT_SECRET"
}
